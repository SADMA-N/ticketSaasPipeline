flowchart TD
    A(["📬 SQS Queue\nhas message"])

    A -->|"worker picks up"| B["⚡ processJob()"]

    B -->|"✅ success"| C["deleteMessage()\nremove from SQS"]
    C --> DONE(["✓ Done"])

    B -->|"❌ throws error"| D["NO deleteMessage()\nmessage stays in SQS"]

    D -->|"visibility timeout\nexpires ~30s"| A

    A -->|"worker picks up\nagain attempt 2"| B

    A -->|"worker picks up\nagain attempt 3"| B

    A -->|"❌ failed 3 times\nmax receive count hit"| DLQ

    DLQ[["💀 Dead Letter Queue\nmessage moved here by SQS"]]

    DLQ -->|"pollDlq() picks up"| H["handleDlqMessage()"]

    H -->|"phase1Done = true"| I["state →\ncompleted_with_fallback"]
    H -->|"phase1Done = false"| J["state →\nneeds_manual_review"]

    I --> K["📝 log + 🔔 socket event\nemitSocketEvent()"]
    J --> K

    K --> DONE2(["✓ Task closed"])

    style DLQ fill:#fef2f2,stroke:#ef4444,color:#000
    style D fill:#fef2f2,stroke:#ef4444,color:#000
    style B fill:#ede9fe,stroke:#7c3aed,color:#000
    style C fill:#ecfdf5,stroke:#10b981,color:#000
    style I fill:#fff7ed,stroke:#f97316,color:#000
    style J fill:#fff7ed,stroke:#f97316,color:#000
    style K fill:#fef3c7,stroke:#f59e0b,color:#000
    style DONE fill:#ecfdf5,stroke:#10b981,color:#000
    style DONE2 fill:#ecfdf5,stroke:#10b981,color:#000
